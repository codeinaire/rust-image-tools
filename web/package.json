{
  "name": "rust-image-converter-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frontend for Rust + WASM image converter",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/image-converter --target web --release",
    "clean": "rm -rf dist .astro",
    "dev": "astro dev",
    "dev:full": "npm run build:wasm && astro dev",
    "build": "npm run build:wasm && astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "tests": "npm run test:rust && npm run test && npm run test:e2e",
    "test:rust": "cargo test --manifest-path ../crates/image-converter/Cargo.toml",
    "test:e2e": "npx playwright test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:all": "npm run typecheck && npm run lint && npm run format:check",
    "bundle-size": "node ../scripts/bundle-size.mjs",
    "bundle-size:build": "node ../scripts/bundle-size.mjs --build"
  },
  "devDependencies": {
    "@astrojs/preact": "^4.1.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24",
    "@vitest/ui": "^4.0.18",
    "astro": "^5",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "jsdom": "^28.1.0",
    "preact": "^10",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wasm-pack": "^0.14.0"
  },
  "overrides": {
    "vite": "^6"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "heic-to": "^1.4.2",
    "posthog-js": "^1.347.2"
  }
}
