---
import Base from '../layouts/Base.astro'
import { ImageConverter } from '../components/ImageConverter'
import { BASE_URL } from '../constants'

const TICKER_REPEATS = 8
const TICKER_CONTAINER_STYLE =
  "font-family: 'Space Grotesk', monospace; font-size: clamp(7rem, 9vw, 9rem); font-weight: 900; letter-spacing: 0.06em; word-spacing: -0.22em; line-height: 1; padding: 0 0.22em; white-space: nowrap;"
const LETTER_SHADOW =
  '0 1px 0 #b8a800, 0 2px 0 #a09200, 0 3px 0 #887c00, 0 4px 0 #706600, 0 5px 0 #585000, 0 6px 12px var(--cp-shadow-strong), 0 0 20px var(--cp-yellow), 0 0 60px var(--cp-yellow-glow-strong), 0 0 100px var(--cp-yellow-glow-soft)'
const LETTERS: { ch: string; dur: number; delay: number }[] = [
  { ch: 'I', dur: 0, delay: 0.0 },
  { ch: 'M', dur: 7.5, delay: 1.2 },
  { ch: 'A', dur: 0, delay: 0.0 },
  { ch: 'G', dur: 0, delay: 0.0 },
  { ch: 'E', dur: 0, delay: 0.0 },
  { ch: '\u00A0', dur: 0, delay: 0.0 },
  { ch: 'T', dur: 0, delay: 0.0 },
  { ch: 'O', dur: 0, delay: 0.0 },
  { ch: 'O', dur: 0, delay: 0.0 },
  { ch: 'L', dur: 0, delay: 0.0 },
  { ch: 'Z', dur: 8.2, delay: 3.7 },
]

const title = 'Free Image Converter — PNG, JPEG, WebP, GIF, BMP, TIFF, ICO, QOI, TGA | Online & Private'
const description =
  'Convert images between PNG, JPEG, WebP, GIF, BMP, TIFF, ICO, QOI, and TGA instantly in your browser. No upload to any server — 100% private, free, and fast.'
const canonical = `${BASE_URL}/`

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I convert a PNG to JPEG?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Drop your PNG file onto the converter, select JPEG as the output format, and click Convert. Your converted file downloads instantly — no server upload required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is this image converter safe to use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. All conversion happens directly in your browser — your images are never uploaded to any server and nothing leaves your device.',
      },
    },
    {
      '@type': 'Question',
      name: 'What image formats are supported?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You can convert between PNG, JPEG, WebP, GIF, BMP, TIFF, ICO, and QOI — all supported as both input and output. TGA is output only. HEIC/HEIF is accepted as input only — drop an iPhone photo to convert it to any supported format.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the maximum file size?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Files up to 200 MB are supported. Images can be up to 100 megapixels.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why can\'t I export to HEIC?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'HEIC encoding is not supported because the HEVC video codec it relies on is covered by patents held by the MPEG LA patent pool. Implementing an encoder would require a commercial licence. HEIC input is supported — you can open any HEIC file and convert it to a patent-free format like PNG, WebP, or JPEG.',
      },
    },
  ],
}
---

<style>
  @media (max-width: 480px) {
    .cp-tagline {
      letter-spacing: 0.08em !important;
      font-size: 0.75rem !important;
    }
  }
</style>

<Base title={title} description={description} canonical={canonical}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ░░ SCROLLING TICKER HEADER ░░ -->
  <div
    style="width: 100%; overflow-x: hidden; background: linear-gradient(to bottom, var(--cp-panel) 50%, var(--cp-bg) 100%); padding-bottom: 1rem; padding-top: 1rem;"
  >
    <!-- Screen-reader title (ticker is aria-hidden) -->
    <h1 class="sr-only">Image Toolz — Free Image Converter</h1>
    <div
      aria-hidden="true"
      style="display: flex; width: max-content; animation: ticker-scroll 28s linear infinite; will-change: transform;"
    >
      {
        Array.from({ length: TICKER_REPEATS }, (_, i) => (
          <span style={TICKER_CONTAINER_STYLE}>
            {LETTERS.map(({ ch, dur, delay }) => (
              <span
                style={`display: inline-block; color: var(--cp-yellow); text-shadow: ${LETTER_SHADOW};${dur > 0 ? ` animation: neon-flicker ${dur}s ease-in-out ${delay}s infinite;` : ''}`}
              >
                {ch}
              </span>
            ))}
          </span>
        ))
      }
    </div>
    <!-- ░░ TAGLINE ░░ -->
    <div
      style="text-align: center; padding: 1rem 1rem 0; border-bottom: 1px solid var(--cp-border);"
    >
      <p class="cp-tagline" style="color: var(--cp-text); font-size: 0.85rem; letter-spacing: 0.25em; padding-bottom: 1rem; white-space: nowrap;">
        ◆ FAST · FUTURISTIC · FREE ◆
      </p>
    </div>
  </div>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <!-- Interactive converter island (client:only because it uses Worker/WASM browser APIs) -->
    <ImageConverter client:only="preact" />

    <!-- ░░ THREE PILLARS ░░ -->
    <section style="margin-top: 3rem;">
      <div class="grid sm:grid-cols-3 gap-3">
        <!-- HOW IT WORKS -->
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-top: 3px solid var(--cp-cyan); padding: 2rem 1.75rem; text-align: center;"
        >
          <div style="margin-bottom: 1.25rem; display: flex; justify-content: center;">
            <svg
              width="38"
              height="38"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--cp-cyan)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="filter: drop-shadow(0 0 6px var(--cp-cyan-glow));"
            >
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M3 12h6M15 12h6M12 3v6M12 15v6"></path>
            </svg>
          </div>
          <h2
            style="font-family: 'Orbitron', monospace; color: var(--cp-yellow); font-size: 0.85rem; letter-spacing: 0.15em; margin-bottom: 0.9rem;"
          >
            // HOW IT WORKS
          </h2>
          <p style="color: var(--cp-text); font-size: 0.85rem; line-height: 1.75;">
            Drop your image, pick a target format, and hit Execute. The converted file downloads
            straight to your device. No sign-up, no steps. Easy.
          </p>
        </div>

        <!-- ZERO EXPOSURE -->
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-top: 3px solid var(--cp-cyan); padding: 2rem 1.75rem; text-align: center;"
        >
          <div style="margin-bottom: 1.25rem; display: flex; justify-content: center;">
            <svg
              width="38"
              height="38"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--cp-cyan)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="filter: drop-shadow(0 0 6px var(--cp-cyan-glow));"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h2
            style="font-family: 'Orbitron', monospace; color: var(--cp-yellow); font-size: 0.85rem; letter-spacing: 0.15em; margin-bottom: 0.9rem;"
          >
            // ZERO EXPOSURE
          </h2>
          <p style="color: var(--cp-text); font-size: 0.85rem; line-height: 1.75;">
            Your images never leave your device. Everything runs directly in your browser. No
            server, no logs, nothing uploaded. Ever.
          </p>
        </div>

        <!-- NEAR-NATIVE SPEED -->
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-top: 3px solid var(--cp-cyan); padding: 2rem 1.75rem; text-align: center;"
        >
          <div style="margin-bottom: 1.25rem; display: flex; justify-content: center;">
            <svg
              width="38"
              height="38"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--cp-cyan)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="filter: drop-shadow(0 0 6px var(--cp-cyan-glow));"
            >
              <polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polyline>
            </svg>
          </div>
          <h2
            style="font-family: 'Orbitron', monospace; color: var(--cp-yellow); font-size: 0.85rem; letter-spacing: 0.15em; margin-bottom: 0.9rem;"
          >
            // NATIVE SPEED
          </h2>
          <p style="color: var(--cp-text); font-size: 0.85rem; line-height: 1.75;">
            Well, near native speed. Most conversions finish in under a second. No upload delays, no
            server queues. Just instant results the moment you hit Execute.
          </p>
        </div>
      </div>
    </section>

    <!-- ░░ SUPPORTED FORMATS ░░ -->
    <section style="margin-top: 3rem;">
      <h2
        style="font-family: 'Orbitron', monospace; color: var(--cp-yellow); font-size: 1rem; letter-spacing: 0.15em; margin-bottom: 1.25rem;"
      >
        // SUPPORTED FORMATS
      </h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            PNG
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Lossless compression with transparency support. Ideal for graphics, logos, and
            screenshots.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            JPEG
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Lossy compression optimized for photographs. Produces smaller file sizes for
            photo-realistic images.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            WEBP
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Modern format by Google supporting both lossy and lossless compression. Supported as
            both an input and output format.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            GIF
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Supports animation and simple transparency. Best for short animations and simple
            graphics.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            BMP
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Uncompressed bitmap format. Large files but universal compatibility and no quality loss.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            TIFF
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            High-quality format used in professional and print workflows. Common output from cameras
            and scanners. Lossless with large file sizes.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            ICO
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Windows icon format. Convert any image to ICO for use as a favicon or application icon.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            QOI
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Quite OK Image — a fast, lossless modern format. Encodes and decodes 3–10× faster than
            PNG for similar file sizes. Great for pipelines that need speed over compression ratio.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            TGA
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Legacy format from the graphics and game industry. Supported as an output format — convert
            any image to TGA for use in tools and pipelines that require it.
          </p>
        </div>
        <div
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); border-left: 3px solid var(--cp-cyan); padding: 1rem;"
        >
          <h3
            style="font-family: 'Orbitron', monospace; color: var(--cp-cyan); font-size: 0.8rem; letter-spacing: 0.1em;"
          >
            HEIC / HEIF
          </h3>
          <p
            style="color: var(--cp-text); font-size: 0.8rem; margin-top: 0.4rem; line-height: 1.5;"
          >
            Apple's default camera format on iPhone and iPad. Accepted as an input — drop a HEIC file
            to convert it to PNG, JPEG, WebP, or any other supported format. HEIC output is not
            supported.
          </p>
        </div>
      </div>
    </section>

    <!-- ░░ FAQ ░░ -->
    <section style="margin-top: 3rem;">
      <h2
        style="font-family: 'Orbitron', monospace; color: var(--cp-yellow); font-size: 1rem; letter-spacing: 0.15em; margin-bottom: 1.25rem;"
      >
        // SYSTEM FAQ
      </h2>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <details
          class="cyber-details"
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); padding: 1rem;"
        >
          <summary style="color: var(--cp-text); font-size: 0.875rem; letter-spacing: 0.05em;">
            How do I convert a PNG to JPEG?
          </summary>
          <p
            style="margin-top: 0.75rem; color: var(--cp-text); font-size: 0.8rem; line-height: 1.6;"
          >
            Drop your PNG file onto the converter, select JPEG as the output format, and click
            Execute. Your converted file downloads instantly — no server upload required.
          </p>
        </details>
        <details
          class="cyber-details"
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); padding: 1rem;"
        >
          <summary style="color: var(--cp-text); font-size: 0.875rem; letter-spacing: 0.05em;">
            Is this image converter safe to use?
          </summary>
          <p
            style="margin-top: 0.75rem; color: var(--cp-text); font-size: 0.8rem; line-height: 1.6;"
          >
            Yes. All conversion happens directly in your browser — your images are never uploaded to
            any server and nothing leaves your device.
          </p>
        </details>
        <details
          class="cyber-details"
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); padding: 1rem;"
        >
          <summary style="color: var(--cp-text); font-size: 0.875rem; letter-spacing: 0.05em;">
            What image formats are supported?
          </summary>
          <p
            style="margin-top: 0.75rem; color: var(--cp-text); font-size: 0.8rem; line-height: 1.6;"
          >
            You can convert between PNG, JPEG, WebP, GIF, BMP, TIFF, ICO, and QOI — all supported
            as both input and output. TGA is output only. HEIC/HEIF is accepted as input only — drop
            an iPhone photo to convert it to any supported format.
          </p>
        </details>
        <details
          class="cyber-details"
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); padding: 1rem;"
        >
          <summary style="color: var(--cp-text); font-size: 0.875rem; letter-spacing: 0.05em;">
            What is the maximum file size?
          </summary>
          <p
            style="margin-top: 0.75rem; color: var(--cp-text); font-size: 0.8rem; line-height: 1.6;"
          >
            Files up to 200 MB are supported. Images can be up to 100 megapixels.
          </p>
        </details>
        <details
          class="cyber-details"
          style="background: var(--cp-panel); border: 1px solid var(--cp-border); padding: 1rem;"
        >
          <summary style="color: var(--cp-text); font-size: 0.875rem; letter-spacing: 0.05em;">
            Why can't I export to HEIC?
          </summary>
          <p
            style="margin-top: 0.75rem; color: var(--cp-text); font-size: 0.8rem; line-height: 1.6;"
          >
            HEIC encoding is not supported because the HEVC video codec it relies on is covered by
            patents held by the MPEG LA patent pool. Implementing an encoder would require a
            commercial licence. HEIC input is supported — you can open any HEIC file and convert it
            to a patent-free format like PNG, WebP, or JPEG.
          </p>
        </details>
      </div>
    </section>
  </main>

  <!-- ░░ FOOTER ░░ -->
  <footer
    style="margin-top: 3rem; border-top: 1px solid var(--cp-border); background: var(--cp-panel);"
  >
    <div class="max-w-4xl mx-auto px-4 py-6" style="text-align: center;">
      <p style="color: var(--cp-muted); font-size: 0.85rem; letter-spacing: 0.2em;">
        ◆ &nbsp;<span style="color: var(--cp-text);">WELCOME TO THE FUTURE</span> &nbsp; ◆
      </p>
    </div>
  </footer>
</Base>
